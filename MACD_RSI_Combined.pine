//@version=6
// Note: timeframe/timeframe_gaps removed — drawings are side effects (CE10080)
indicator("Moving Average Convergence Divergence", "MACD")

// ─── Original inputs ───────────────────────────────────────────────────────
float  sourceInput  = input.source(close, "Source")
int    fastLenInput = input.int(12, "Fast length",   minval=1)
int    slowLenInput = input.int(26, "Slow length",   minval=1)
int    sigLenInput  = input.int(9,  "Signal length", minval=1)
string oscTypeInput = input.string("EMA", "Oscillator MA type", ["EMA", "SMA"], display = display.none)
string sigTypeInput = input.string("EMA", "Signal MA type",     ["EMA", "SMA"], display = display.none)

// ─── Divergence inputs ─────────────────────────────────────────────────────
string grpDiv      = "Divergences"
bool   showRegBull = input.bool(true,  "Regular Bullish", inline="rb", group=grpDiv, tooltip="Price: LL | MACD: HL → reversal al rialzo")
color  colRegBull  = input.color(color.new(color.green, 0), "", inline="rb", group=grpDiv)
bool   showRegBear = input.bool(true,  "Regular Bearish", inline="rr", group=grpDiv, tooltip="Price: HH | MACD: LH → reversal al ribasso")
color  colRegBear  = input.color(color.new(color.red,   0), "", inline="rr", group=grpDiv)
bool   showHidBull = input.bool(false, "Hidden Bullish",  inline="hb", group=grpDiv, tooltip="Price: HL | MACD: LL → continuazione rialzista")
color  colHidBull  = input.color(color.new(#00bcd4,    0), "", inline="hb", group=grpDiv)
bool   showHidBear = input.bool(false, "Hidden Bearish",  inline="hr", group=grpDiv, tooltip="Price: LH | MACD: HH → continuazione ribassista")
color  colHidBear  = input.color(color.new(#ff9800,    0), "", inline="hr", group=grpDiv)
int    pivLeft     = input.int(5,  "Pivot Left Bars",   group=grpDiv, minval=1, maxval=50)
int    pivRight    = input.int(5,  "Pivot Right Bars",  group=grpDiv, minval=1, maxval=50)
int    lookback    = input.int(60, "Max Lookback Bars", group=grpDiv, minval=5, maxval=500)

// ─── MA helper ─────────────────────────────────────────────────────────────
ma(float source, int length, simple string maType) =>
    switch maType
        "EMA" => ta.ema(source, length)
        "SMA" => ta.sma(source, length)

// ─── MACD calculation ──────────────────────────────────────────────────────
float maFast = ma(sourceInput, fastLenInput, oscTypeInput)
float maSlow = ma(sourceInput, slowLenInput, oscTypeInput)
float macd   = maFast - maSlow
float signal = ma(macd, sigLenInput, sigTypeInput)
float hist   = macd - signal
color hColor = hist >= 0 ? hist > hist[1] ? #26a69a : #b2dfdb : hist > hist[1] ? #ffcdd2 : #ff5252

// ─── Base plots ────────────────────────────────────────────────────────────
hline(0, "Zero", #787b8680)
plot(hist,   "Histogram",   hColor, style = plot.style_columns)
plot(macd,   "MACD")
plot(signal, "Signal line", #ff6d00)

// ─── Original alerts ───────────────────────────────────────────────────────
alertcondition(hist[1] >= 0 and hist < 0, "Rising to falling", "MACD histogram switched from a rising to falling state")
alertcondition(hist[1] <= 0 and hist > 0, "Falling to rising", "MACD histogram switched from a falling to rising state")

// ══════════════════════════════════════════════════════════════════════════
//  DIVERGENCE DETECTION
//  Pivots rilevati sulla linea MACD; il prezzo agli stessi bar per confronto.
//  Ogni pivot corrente viene confrontato con il più recente pivot precedente.
// ══════════════════════════════════════════════════════════════════════════
float pivHigh = ta.pivothigh(macd, pivLeft, pivRight)
float pivLow  = ta.pivotlow (macd, pivLeft, pivRight)

bool regBullDiv = false
bool regBearDiv = false
bool hidBullDiv = false
bool hidBearDiv = false

// ── Low pivots → divergenze rialziste ─────────────────────────────────────
if not na(pivLow)
    float curMacdLow  = pivLow
    float curPriceLow = low[pivRight]
    int   curBar      = bar_index - pivRight

    for i = 1 to lookback
        if not na(pivLow[i])
            float prevMacdLow  = pivLow[i]
            float prevPriceLow = low[pivRight + i]
            int   prevBar      = bar_index - pivRight - i

            // Regular Bull: prezzo LL, MACD HL
            if curPriceLow < prevPriceLow and curMacdLow > prevMacdLow
                regBullDiv := true
                if showRegBull
                    line.new (prevBar, prevMacdLow, curBar, curMacdLow,
                              color=colRegBull, width=2)
                    label.new(curBar, curMacdLow, "Bull",
                              color=colRegBull, textcolor=color.white,
                              style=label.style_label_up, size=size.small)

            // Hidden Bull: prezzo HL, MACD LL
            else if curPriceLow > prevPriceLow and curMacdLow < prevMacdLow
                hidBullDiv := true
                if showHidBull
                    line.new (prevBar, prevMacdLow, curBar, curMacdLow,
                              color=colHidBull, width=2, style=line.style_dashed)
                    label.new(curBar, curMacdLow, "H.Bull",
                              color=colHidBull, textcolor=color.white,
                              style=label.style_label_up, size=size.small)
            break

// ── High pivots → divergenze ribassiste ───────────────────────────────────
if not na(pivHigh)
    float curMacdHigh  = pivHigh
    float curPriceHigh = high[pivRight]
    int   curBar       = bar_index - pivRight

    for i = 1 to lookback
        if not na(pivHigh[i])
            float prevMacdHigh  = pivHigh[i]
            float prevPriceHigh = high[pivRight + i]
            int   prevBar       = bar_index - pivRight - i

            // Regular Bear: prezzo HH, MACD LH
            if curPriceHigh > prevPriceHigh and curMacdHigh < prevMacdHigh
                regBearDiv := true
                if showRegBear
                    line.new (prevBar, prevMacdHigh, curBar, curMacdHigh,
                              color=colRegBear, width=2)
                    label.new(curBar, curMacdHigh, "Bear",
                              color=colRegBear, textcolor=color.white,
                              style=label.style_label_down, size=size.small)

            // Hidden Bear: prezzo LH, MACD HH
            else if curPriceHigh < prevPriceHigh and curMacdHigh > prevMacdHigh
                hidBearDiv := true
                if showHidBear
                    line.new (prevBar, prevMacdHigh, curBar, curMacdHigh,
                              color=colHidBear, width=2, style=line.style_dashed)
                    label.new(curBar, curMacdHigh, "H.Bear",
                              color=colHidBear, textcolor=color.white,
                              style=label.style_label_down, size=size.small)
            break

// ── Alert conditions per le divergenze ────────────────────────────────────
alertcondition(regBullDiv, "Regular Bullish Div.", "MACD Regular Bullish Divergence on {{ticker}} ({{interval}})")
alertcondition(regBearDiv, "Regular Bearish Div.", "MACD Regular Bearish Divergence on {{ticker}} ({{interval}})")
alertcondition(hidBullDiv, "Hidden Bullish Div.",  "MACD Hidden Bullish Divergence on {{ticker}} ({{interval}})")
alertcondition(hidBearDiv, "Hidden Bearish Div.",  "MACD Hidden Bearish Divergence on {{ticker}} ({{interval}})")
